OPENAI_API_KEY=replace_with_your_api_key
OPENAI_BASE_URL=https://your-provider.example.com/v1
OPENAI_MODEL=your-model-name
EMBEDDING_KEY=replace_with_your_embedding_api_key
EMBEDDING_BASE_URL=https://your-embedding-provider.example.com/v1
EMBEDDING_MODEL=your-embedding-model-name
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-replace_with_your_tavily_key
# Optional provider-independent override; takes priority over TAVILY_API_KEY.
# WEB_SEARCH_API_KEY=replace_with_your_search_api_key
WEB_SEARCH_BASE_URL=https://api.tavily.com
WEB_SEARCH_TIMEOUT_SECONDS=7

# Optional rerank endpoint. For DashScope qwen3-vl-rerank, the client auto-selects the native endpoint.
RERANK_API_KEY=
RERANK_BASE_URL=https://dashscope.aliyuncs.com
RERANK_MODEL=qwen3-vl-rerank
RERANK_TIMEOUT_SECONDS=5
